#!/bin/bash
# First-boot setup — generates secrets and writes /etc/eneo/env.
# Run once after deploying the bootc image. Re-running is safe (exits early if env exists).

set -euo pipefail

ENV_FILE=/etc/eneo/env

if [[ -f "$ENV_FILE" ]]; then
    echo "ERROR: $ENV_FILE already exists. Remove it first to re-run setup."
    exit 1
fi

echo "=== Eneo first-boot setup ==="
echo

read -rp "Public hostname (e.g. eneo.example.com): " ENEO_HOST
read -rsp "Admin password for first login:           " DEFAULT_USER_PASSWORD
echo

echo "Generating secrets..."
POSTGRES_PASSWORD=$(openssl rand -hex 32)
JWT_SECRET=$(openssl rand -hex 32)
URL_SIGNING_KEY=$(openssl rand -hex 32)
ENEO_SUPER_API_KEY=$(openssl rand -hex 32)
ENCRYPTION_KEY=$(python3 -c "import os, base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())")

mkdir -p /etc/eneo

cat > "$ENV_FILE" << EOF
# Generated by eneo-setup — do not commit this file
# Recreate with: rm $ENV_FILE && eneo-setup

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=eneo-postgres
POSTGRES_PORT=5432
POSTGRES_USER=eneo
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=eneo

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=eneo-redis
REDIS_PORT=6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=${JWT_SECRET}
JWT_AUDIENCE=*
JWT_ISSUER=ENEO
JWT_EXPIRY_TIME=86400
JWT_ALGORITHM=HS256
JWT_TOKEN_PREFIX=Bearer
URL_SIGNING_KEY=${URL_SIGNING_KEY}

# Required for the admin model-provider UI (encrypts stored API keys)
ENCRYPTION_KEY=${ENCRYPTION_KEY}

# ── API ───────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1
API_KEY_LENGTH=64
API_KEY_HEADER_NAME=X-API-Key
ENEO_SUPER_API_KEY=${ENEO_SUPER_API_KEY}
ENEO_SUPER_DUPER_API_KEY=

# ── Public URL ────────────────────────────────────────────────────────────────
ENEO_HOST=${ENEO_HOST}
PUBLIC_ORIGIN=https://${ENEO_HOST}

# ── Frontend ──────────────────────────────────────────────────────────────────
# Server-side SvelteKit SSR reaches the backend directly on the Podman network
ENEO_BACKEND_SERVER_URL=http://eneo-backend:8000
# Browser-side fetches go to the public URL
ENEO_BACKEND_URL=https://${ENEO_HOST}
PUBLIC_ENEO_BACKEND_URL=https://${ENEO_HOST}
ORIGIN=https://${ENEO_HOST}

# ── OIDC (optional — leave empty to use built-in username/password login) ─────
OIDC_DISCOVERY_ENDPOINT=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_STATE_TTL_SECONDS=600
OIDC_REDIRECT_GRACE_PERIOD_SECONDS=600
OIDC_CLOCK_LEEWAY_SECONDS=120
STRICT_OIDC_REDIRECT_VALIDATION=true

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
FEDERATION_PER_TENANT_ENABLED=false
TENANT_CREDENTIALS_ENABLED=false

# ── Feature flags ─────────────────────────────────────────────────────────────
USING_ACCESS_MANAGEMENT=True

# ── Upload limits (bytes) ─────────────────────────────────────────────────────
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_FILE_TO_SESSION_MAX_SIZE=10485760
UPLOAD_IMAGE_TO_SESSION_MAX_SIZE=10485760
TRANSCRIPTION_MAX_FILE_SIZE=209715200

# ── Azure OpenAI (optional) ───────────────────────────────────────────────────
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_API_BASE=
AZURE_MODEL_DEPLOYMENT=
AZURE_API_VERSION=2024-02-15-preview

# ── LLM provider keys (configure via admin UI after first login) ──────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
VLLM_API_KEY=
FLUX_API_KEY=
TAVILY_API_KEY=

# ── Default tenant and user ───────────────────────────────────────────────────
DEFAULT_TENANT_NAME=DefaultTenant
DEFAULT_TENANT_QUOTA_LIMIT=10737418240
DEFAULT_USER_NAME=Admin
DEFAULT_USER_EMAIL=admin@example.com
DEFAULT_USER_PASSWORD=${DEFAULT_USER_PASSWORD}
EOF

chmod 600 "$ENV_FILE"

echo
echo "=== Setup complete ==="
echo
echo "Configuration written to $ENV_FILE"
echo
echo "Start Eneo:"
echo "  systemctl start eneo-caddy"
echo
echo "First login: https://${ENEO_HOST}"
echo "  Email:    admin@example.com"
echo "  Password: (the one you just set)"
echo
echo "Change the admin password immediately after first login."
